# Database
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/finance_app

# JWT
SECRET_KEY=your-secret-key-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Groq
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Google AI Studio (fallback)
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxx

# Veryfi OCR
VERYFI_CLIENT_ID=xxxxx
VERYFI_CLIENT_SECRET=xxxxx
VERYFI_USERNAME=xxxxx
VERYFI_API_KEY=xxxxx

# n8n Jelly chatbot webhook
# Sau khi import workflow vào n8n và activate, lấy Webhook URL từ node "When chat message received"
# Dev local:  http://localhost:5678/webhook/<webhookId>/chat
# Docker:     http://n8n:5678/webhook/<webhookId>/chat
N8N_WEBHOOK_URL=http://localhost:5678/webhook/YOUR_WEBHOOK_ID/chat

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
